---
interface Props {
  example: {
    title: string;
    subtitle: string;
    without: string;
    with: string;
    withoutFoot: string;
    withFoot: string;
    copy: string;
    copied: string;
  };
}

const { example } = Astro.props;

const beforeSnippet = `function Modal({ open, onClose, title, children }) {
  useEffect(() => {
    document.addEventListener("keydown", onEscape);
    document.body.style.overflow = "hidden";
    return () => { /* cleanup */ };
  }, [open]);
  return createPortal(
    <div className="modal-overlay" onClick={onClose}>
      <div role="dialog" onClick={(e) => e.stopPropagation()}>
        <h2>{title}</h2>
        {children}
      </div>
    </div>,
    document.body,
  );
}`;

const afterSnippet = `// lexis: native <dialog> — backdrop + focus trap built in
<dialog ref={dialogRef}>
  <h2>Confirm delete</h2>
  <form method="dialog">
    <button value="cancel">Cancel</button>
    <button value="confirm">Delete</button>
  </form>
</dialog>`;
---

<section id="example">
  <div class="wrap">
    <div class="section-head">
      <h2>{example.title}</h2>
      <p set:html={example.subtitle} />
    </div>
    <div class="compare">
      <article class="panel">
        <div class="panel-head bad">{example.without}</div>
        <div class="panel-body">
          <pre><code>{beforeSnippet}</code></pre>
        </div>
        <p class="panel-foot">{example.withoutFoot}</p>
      </article>
      <article class="panel">
        <div class="panel-head good">{example.with}</div>
        <div class="panel-body">
          <button
            data-copied={example.copied}
            type="button"
            class="copy-btn"
            data-copy={afterSnippet}
          >
            {example.copy}
          </button>
          <pre><code>{afterSnippet}</code></pre>
        </div>
        <p class="panel-foot"><strong set:html={example.withFoot} /></p>
      </article>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll(".copy-btn").forEach(function (btn) {
    btn.addEventListener("click", function () {
      var text = btn.getAttribute("data-copy");
      navigator.clipboard.writeText(text!).then(function () {
        var prev = btn.textContent;
        var copiedText = btn.getAttribute("data-copied") || "Copied";
        btn.textContent = copiedText;
        setTimeout(function () {
          btn.textContent = prev;
        }, 1500);
      });
    });
  });
</script>
